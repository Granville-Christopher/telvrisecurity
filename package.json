{
  "name": "telvri-identity-security-api",
  "version": "1.0.0",
  "description": "Developer-first Telco Identity Security API built with NestJS and TypeScript for Telvri Security.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build && node scripts/copy-swagger-ui.mjs",
    "format": "prettier --write \"src/**/*.ts\"",
    "run": "node ./node_modules/@nestjs/cli/bin/nest.js start",
    "start": "node ./node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node dist/main.js",
    "sdk:fetch-spec": "curl -s https://telvrisecurity.vercel.app/docs-json -o openapi.json",
    "sdk:generate": "node scripts/generate-sdks.mjs",
    "sdk:generate:go": "node scripts/generate-sdks.mjs go",
    "sdk:generate:java": "node scripts/generate-sdks.mjs java"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "mongoose": "^9.7.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/swagger-ui-express": "^4.1.7",
    "@vercel/node": "^3.2.29",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
